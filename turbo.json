{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "globalEnv": ["DATABASE_URL"],

  "tasks": {
    "db:generate": {
      "cache": false
    },

    "build": {
      "dependsOn": [
        "db:generate",   
        "^build"           
      ],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },

    "dev": {
      "dependsOn": ["db:generate"],
      "cache": false,
      "persistent": true
    },

    "lint": {
      "dependsOn": ["^lint"]
    },

    "check-types": {
      "dependsOn": ["^check-types"]
    },

    "db:migrate": {
      "cache": false
    },

    "db:deploy": {
      "cache": false
    }
  }
}