    "packages/*"
  ],
  "dependencies": {
    "axios": "^1.14.0",
    "bcrypt": "^6.0.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.7.0",
    "zustand": "^5.0.12"
  }
